					},
					"LS_DEV_ADLS1_properties_typeProperties_url": {
						"value": "[parameters('LS_DEV_ADLS1_properties_typeProperties_url')]"
					},
					"LS_DEV_SNOWFLAKE2_properties_typeProperties_baseUrl": {
						"value": "[parameters('LS_DEV_SNOWFLAKE2_properties_typeProperties_baseUrl')]"
					},
					"Sftp_elson_properties_typeProperties_host": {
						"value": "[parameters('Sftp_elson_properties_typeProperties_host')]"
					},
					"Sftp_elson_properties_typeProperties_userName": {
						"value": "[parameters('Sftp_elson_properties_typeProperties_userName')]"
					},
					"linkedService1_properties_typeProperties_serviceEndpoint": {
						"value": "[parameters('linkedService1_properties_typeProperties_serviceEndpoint')]"
